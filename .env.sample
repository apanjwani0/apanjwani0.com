# ── GitHub stats (optional) ────────────────────────────────────────────────────
# Personal access token (no scopes needed for public repos).
# Without this, the GitHub API allows 60 requests/hr per IP.
# With this, the limit rises to 5000/hr.
GITHUB_TOKEN=

# ── Admin panel ────────────────────────────────────────────────────────────────
# Password for /admin. Required in production; leave unset in dev to bypass auth.
ADMIN_SECRET=your_secret_here

# ── Docker deployment (optional) ───────────────────────────────────────────────
# Used by scripts/deploy-cloud.sh when no positional argument is given.
# Format: registry/image:tag  (e.g. ghcr.io/your-username/portfolio:latest)
DOCKER_IMAGE=ghcr.io/your-username/portfolio:latest

# ── Cloudflare Workers deployment (optional) ───────────────────────────────────
# KV namespace IDs go in wrangler.jsonc, not here.
# Set the admin secret as a Cloudflare secret instead:
#   npx wrangler secret put ADMIN_SECRET
