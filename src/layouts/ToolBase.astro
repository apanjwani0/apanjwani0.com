---
import { getSite } from '../lib/config'
import Nav from '../components/Nav.astro'
import Head from '../components/Head.astro'
import '../styles/shared.css'

interface Props {
  toolTitle?: string
  seoTitle?: string
  metaDescription?: string
}

const site = await getSite(Astro.locals)
const { toolTitle, seoTitle, metaDescription } = Astro.props
const pageTitle = seoTitle || (toolTitle ? `${toolTitle} · ${site.name}` : `${site.name} · tools`)
const description = metaDescription || site.tagline
const canonicalURL = new URL(Astro.url.pathname, site.url).href
---

<!doctype html>
<html lang="en" data-theme={site.theme}>
  <head>
    <Head
      pageTitle={pageTitle}
      description={description}
      canonicalURL={canonicalURL}
      siteName={site.name}
    />
  </head>
  <body>
    <Nav site={site} />
    <slot />
    <script src="/oat.min.js" defer></script>
  </body>
</html>

<style is:global>
  body {
    font-family: var(--font-serif);
    background-color: var(--color-bg);
    color: var(--color-text);
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  a:hover {
    text-decoration: underline;
  }

  header {
    max-width: var(--max-width);
    margin-left: auto;
    margin-right: auto;
  }
</style>
