---
import { getSite } from '../lib/config'
import Nav from '../components/Nav.astro'
import Head from '../components/Head.astro'
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  noindex?: boolean
}

const site = await getSite(Astro.locals)
const { title, description = site.tagline, noindex = false } = Astro.props
const pageTitle = title ? `${title} · ${site.name}` : site.name
const canonicalURL = new URL(Astro.url.pathname, site.url).href
---

<!doctype html>
<html lang="en" data-theme={site.theme}>
  <head>
    <Head
      pageTitle={pageTitle}
      description={description}
      canonicalURL={canonicalURL}
      siteName={site.name}
      noindex={noindex}
    />
  </head>
  <body>
    <Nav site={site} />
    <main>
      <slot />
    </main>
    <script src="/oat.min.js" defer></script>
  </body>
</html>
