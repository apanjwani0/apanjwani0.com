---
export const prerender = false

import Base from '../layouts/Base.astro'
import SocialLinks from '../components/SocialLinks.astro'
import { Image } from 'astro:assets'
import { getSite } from '../lib/config'
import { personJsonLd } from '../lib/jsonld'

const site = await getSite(Astro.locals)
const firstName = site.name.split(' ')[0]

const sameAs = [site.social.github, site.social.linkedin].filter(Boolean)
const ldJson = personJsonLd({
  name: site.name,
  url: site.url,
  jobTitle: site.tagline,
  description: site.bio,
  sameAs,
  image: `${site.url}/avatar.webp`,
})
---

<Base keywords={`${site.name}, ${site.handle}, portfolio, software engineer`}>
  <script type="application/ld+json" set:html={ldJson} />
  <section data-type="hero">
    <div data-type="hero-layout">
      <Image src={site.avatar} width={120} height={120} alt={site.name} data-type="avatar" loading="eager" />
      <div data-type="hero-text">
        <h1>Hi, I'm {firstName}</h1>
        <p data-type="tagline">{site.tagline}</p>
        <SocialLinks site={site} />
      </div>
    </div>
    <p data-type="bio">{site.bio}</p>
  </section>

  {/* TODO: dashboard sections — uncomment when ready
  <section data-type="dashboard">
    <div data-type="dash-section">
      <h2>explore</h2>
      <ul data-type="dash-list">
        {site.sections.experience && (
          <li>
            <a href="/experience">experience</a>
          </li>
        )}
        {site.sections.blogs && (
          <li>
            <a href="/blogs">blogs</a>
          </li>
        )}
      </ul>
    </div>
  </section>
  */}
</Base>
