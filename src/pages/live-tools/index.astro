---
export const prerender = true

import Base from '../../layouts/Base.astro'
import { tools } from '../../config/tools'
import '../../styles/tools.css'
---

<Base title="live tools">
  <h1>live tools</h1>
  <ul data-type="preview-list">
    {tools.map(tool => (
      <li data-status={tool.status}>
        {tool.status === 'wip'
          ? <span data-type="tool-name">{tool.title}</span>
          : <a
              href={tool.status === 'external' ? tool.href! : `/live-tools/${tool.slug}`}
              {...(tool.status === 'external' ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >{tool.title}</a>
        }
        {' — '}
        <span data-type="tool-description">{tool.description}</span>
        {tool.status === 'wip' && <span data-type="tool-wip"> · coming soon</span>}
      </li>
    ))}
  </ul>
</Base>
