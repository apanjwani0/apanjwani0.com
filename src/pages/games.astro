---
export const prerender = false

import Base from '../layouts/Base.astro'
import { getGames } from '../lib/config'

const games = (await getGames(Astro.locals)).filter(g => g.enabled)
---

<Base title="games">
  <h1>games</h1>
  {games.length === 0 ? (
    <p>Coming soon.</p>
  ) : (
    <ul data-type="games-list">
      {games.map(g => (
        <li>
          <h3>{g.title}</h3>
          <p>{g.description}</p>
          <span data-type="games-status">coming soon</span>
        </li>
      ))}
    </ul>
  )}
</Base>
